generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum DocumentSourceType {
  APPLICATION_PROFILE
  APPLICATION_NOTES
  RECRUITER_CONTEXT
  JOB_POSTING
}

model Application {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      String
  role         String
  link         String?
  stage        String   @default("applied") // applied, interview, rejected, offer
  dateApplied  String   // YYYY-MM-DD local date
  notes        String?
  followUpDate String?  // YYYY-MM-DD local date
  recruiterName     String?
  recruiterTitle    String?
  recruiterEmail    String?
  recruiterLinkedIn String?
  recruiterSource   String?

  reminders    Reminder[]
  documents    ApplicationDocument[]
  chunks       DocumentChunk[]
}

model DailyGoal {
  id          String @id @default(cuid())
  date        String @unique // YYYY-MM-DD
  targetCount Int    @default(5)
}

model DailyNote {
  id   String @id @default(cuid())
  date String @unique // YYYY-MM-DD
  text String @default("")
}

model Reminder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  date      String   // YYYY-MM-DD
  time      String   // HH:MM (24h)
  message   String
  done      Boolean  @default(false)

  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
}

model ApplicationDocument {
  id           String             @id @default(cuid())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  applicationId String
  sourceType   DocumentSourceType
  title        String
  url          String?
  content      String
  lastSyncedAt DateTime           @default(now())

  application  Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]

  @@unique([applicationId, sourceType])
}

model DocumentChunk {
  id          String              @id @default(cuid())
  createdAt   DateTime            @default(now())
  documentId  String
  applicationId String
  chunkIndex  Int
  content     String
  embedding   String

  document    ApplicationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  application Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([applicationId])
}
